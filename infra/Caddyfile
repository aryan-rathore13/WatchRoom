  # API
  handle /rooms* {
    reverse_proxy localhost:3001
  }
  handle /invite* {
    reverse_proxy localhost:3001
  }
  handle /tokens* {
    reverse_proxy localhost:3001
  }
  handle /health {
    reverse_proxy localhost:3001
  }

  # Frontend
  handle {
    reverse_proxy localhost:3000
  }
}
